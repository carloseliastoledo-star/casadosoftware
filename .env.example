# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:root@localhost:3306/casadosoftware_dev"

# ── JWT / sessão ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=senha-segura

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Pagar.me v5 ───────────────────────────────────────────────────────────────
PAGARME_API_KEY=ak_live_...          # chave secreta (server-side only)
PAGARME_PUBLIC_KEY=pk_live_...       # chave pública (frontend)
PAGARME_WEBHOOK_SECRET=              # segredo para validar assinatura dos webhooks

# ── Mercado Pago (legado) ─────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ── Afiliados ─────────────────────────────────────────────────────────────────
