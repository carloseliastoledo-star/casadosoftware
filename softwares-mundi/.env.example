# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Optional (recommended): protect admin upload endpoints.
# If set, requests to /api/admin/* must send header: Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

# Absolute URLs Stripe should redirect to after payment
# Example: http://localhost:3000/success
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel

# SEO / Canonical base URL (optional but recommended)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
