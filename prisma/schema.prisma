generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  licenseLimit Int      @default(0)
  status       String   @default("active") // active, inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admins      CustomerAdmin[]
  licenses    LicenseAccount[]
  logs        LicenseLog[]
}

model CustomerAdmin {
  id            String   @id @default(cuid())
  customerId    String
  name          String
  email         String
  passwordHash  String
  role          String   @default("admin") // admin, viewer
  status        String   @default("active") // active, inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([email])
}

model LicenseAccount {
  id               String   @id @default(cuid())
  customerId       String
  email            String
  passwordEncrypted String
  tenantDomain     String?
  licenseType      String   // business_basic, business_standard, business_premium
  status           String   @default("active") // active, inactive, expired
  activationStatus String   @default("not_activated") // not_activated, activated, deactivated
  deliveredAt      DateTime?
  lastCheckedAt    DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  logs     LicenseLog[]

  @@index([customerId])
  @@index([email])
  @@index([status])
}

model LicenseLog {
  id              String   @id @default(cuid())
  customerId      String
  licenseAccountId String?
  performedBy     String
  action          String
  metadata        String?  @db.Text
  createdAt       DateTime @default(now())

  customer  Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  license   LicenseAccount? @relation(fields: [licenseAccountId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([licenseAccountId])
  @@index([createdAt])
}